# Backend Worker
DATABASE_URL="postgresql://user:password@ep-example.neon.tech/agentflow?sslmode=require"
GHL_WEBHOOK_SECRET="replace-with-ghl-webhook-signing-secret"
GHL_API_TOKEN="replace-with-private-integrations-token-for-on-demand-contact-details"
GHL_API_BASE_URL="https://services.leadconnectorhq.com"
GHL_CLIENT_ID="replace-with-marketplace-app-client-id"
GHL_CLIENT_SECRET="replace-with-marketplace-app-client-secret"
GHL_APP_ID="replace-with-marketplace-app-id-optional"
GHL_INSTALL_URL="https://marketplace.gohighlevel.com/v2/oauth/chooselocation?response_type=code&client_id=replace-with-marketplace-client-id&version_id=replace-with-version-id"
# Optional: paste the full Installation URL from Developer Portal → your app → Advanced Settings → Auth → Show installation URL.
# When set, it is preferred over GHL_INSTALL_URL (same OAuth screen you use in the iframe, without hand-assembling query params).
GHL_OAUTH_START_URL=""
# Optional: if version_id is omitted from GHL_INSTALL_URL, set it here (same uuid as Marketplace app version).
GHL_VERSION_ID=""
# Optional: override default Marketplace OAuth scopes (space-separated).
GHL_OAUTH_SCOPE=""
GHL_OAUTH_REDIRECT_URI="https://api.agentflow.autowiz.net/oauth/gohighlevel/callback"
GHL_OAUTH_USER_TYPE="Company"
GHL_DEFAULT_WEBHOOK_URL="https://api.agentflow.autowiz.net/webhooks/gohighlevel"
FRONTEND_BASE_URL="https://agentflow.autowiz.net"

# Workspace UI auth (JWT on API). Leave JWT_SECRET unset to keep legacy x-viewer-key mode only.
JWT_SECRET=""

# Frontend Pages
# Cloudflare Worker API origin (must NOT be the Pages app URL or a GCS bucket).
NEXT_PUBLIC_API_BASE_URL="https://agentflow-api.example.workers.dev"

