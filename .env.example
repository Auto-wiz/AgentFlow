# Backend Worker
DATABASE_URL="postgresql://user:password@ep-example.neon.tech/agentflow?sslmode=require"
GHL_WEBHOOK_SECRET="replace-with-ghl-webhook-signing-secret"
GHL_API_TOKEN="replace-with-private-integrations-token-for-on-demand-contact-details"
GHL_API_BASE_URL="https://services.leadconnectorhq.com"
GHL_CLIENT_ID="replace-with-marketplace-app-client-id"
GHL_CLIENT_SECRET="replace-with-marketplace-app-client-secret"
GHL_APP_ID="replace-with-marketplace-app-id-optional"
GHL_INSTALL_URL="https://marketplace.gohighlevel.com/v2/oauth/chooselocation?response_type=code&client_id=replace-with-client-id"
GHL_OAUTH_REDIRECT_URI="https://api.agentflow.autowiz.net/oauth/gohighlevel/callback"
GHL_OAUTH_USER_TYPE="Company"
GHL_OAUTH_SCOPE="contacts.readonly conversations.readonly conversations.write conversations/message.readonly conversations/message.write conversations/reports.readonly conversations/livechat.write locations.readonly locations/tags.readonly locations/tags.write locations/customValues.readonly oauth.write oauth.readonly calendars/events.readonly invoices.readonly invoices/schedule.readonly"
GHL_DEFAULT_WEBHOOK_URL="https://api.agentflow.autowiz.net/webhooks/gohighlevel"
FRONTEND_BASE_URL="https://agentflow.autowiz.net"

# Frontend Pages
